# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
*.egg-info/

# PyRel runtime caches (regenerated on demand). NOTE: build/ holds the demo's
# figure-generation scripts + figures, so ignore only the PyRel cache artifacts
# that PyRel writes into build/ when run from the repo root.
build/cache/
build/runs/
build/*.jsonl
build/metadata.json
rai_code/manual/build/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Secrets / local env
.env
.env.*.local

# Jupyter
.ipynb_checkpoints/
*.executed.ipynb

# Claude Code local overrides
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Demo-day artifacts that should be regenerated, not committed
query_results/
*.log

# Downloaded seed datasets (re-fetched by data/fetch_seeds.py; large)
data/seed/
